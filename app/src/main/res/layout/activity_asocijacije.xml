<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F0F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvRound"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Runda 1 / 2"
                android:textSize="15sp"
                android:textColor="#555555" />

            <TextView
                android:id="@+id/tvScore"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Bodovi: 0"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#272794"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏱ "
                android:textSize="18sp" />

            <TextView
                android:id="@+id/tvTimer"
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                android:text="02:00"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#D32F2F"
                android:gravity="center" />
        </LinearLayout>

        <!-- 4-column grid -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Column 1 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="2dp">

                <Button
                    android:id="@+id/btnC1F1"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginBottom="2dp"
                    android:backgroundTint="#272794"
                    android:text="?"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/btnC1F2"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginBottom="2dp"
                    android:backgroundTint="#272794"
                    android:text="?"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/btnC1F3"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginBottom="2dp"
                    android:backgroundTint="#272794"
                    android:text="?"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/btnC1F4"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginBottom="2dp"
                    android:backgroundTint="#272794"
                    android:text="?"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/btnSolC1"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:backgroundTint="#1A237E"
                    android:text=""
                    android:textColor="#FFFFFF"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Column 2 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp">

                <Button
                    android:id="@+id/btnC2F1"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginBottom="2dp"
                    android:backgroundTint="#272794"
                    android:text="?"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/btnC2F2"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginBottom="2dp"
                    android:backgroundTint="#272794"
                    android:text="?"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/btnC2F3"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginBottom="2dp"
                    android:backgroundTint="#272794"
                    android:text="?"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/btnC2F4"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginBottom="2dp"
                    android:backgroundTint="#272794"
                    android:text="?"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/btnSolC2"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:backgroundTint="#1A237E"
                    android:text=""
                    android:textColor="#FFFFFF"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Column 3 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp">

                <Button
                    android:id="@+id/btnC3F1"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginBottom="2dp"
                    android:backgroundTint="#272794"
                    android:text="?"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/btnC3F2"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginBottom="2dp"
                    android:backgroundTint="#272794"
                    android:text="?"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/btnC3F3"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginBottom="2dp"
                    android:backgroundTint="#272794"
                    android:text="?"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/btnC3F4"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginBottom="2dp"
                    android:backgroundTint="#272794"
                    android:text="?"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/btnSolC3"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:backgroundTint="#1A237E"
                    android:text=""
                    android:textColor="#FFFFFF"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Column 4 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="2dp">

                <Button
                    android:id="@+id/btnC4F1"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginBottom="2dp"
                    android:backgroundTint="#272794"
                    android:text="?"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/btnC4F2"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginBottom="2dp"
                    android:backgroundTint="#272794"
                    android:text="?"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/btnC4F3"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginBottom="2dp"
                    android:backgroundTint="#272794"
                    android:text="?"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/btnC4F4"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginBottom="2dp"
                    android:backgroundTint="#272794"
                    android:text="?"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/btnSolC4"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:backgroundTint="#1A237E"
                    android:text=""
                    android:textColor="#FFFFFF"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Column guess rows -->
        <LinearLayout
            android:id="@+id/rowGuessC1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <EditText
                android:id="@+id/etGuessC1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Kolona 1..."
                android:inputType="text"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btnGuessC1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="#272794"
                android:text="Pogodi"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rowGuessC2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <EditText
                android:id="@+id/etGuessC2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Kolona 2..."
                android:inputType="text"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btnGuessC2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="#272794"
                android:text="Pogodi"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rowGuessC3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <EditText
                android:id="@+id/etGuessC3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Kolona 3..."
                android:inputType="text"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btnGuessC3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="#272794"
                android:text="Pogodi"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rowGuessC4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <EditText
                android:id="@+id/etGuessC4"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Kolona 4..."
                android:inputType="text"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btnGuessC4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="#272794"
                android:text="Pogodi"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Final solution -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnFinalSolution"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#1A237E"
            android:text="KONAČNO REŠENJE"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:layout_marginBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/etGuessFinal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Konačno rešenje..."
                android:inputType="text"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btnGuessFinal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="#1A237E"
                android:text="Pogodi"
                android:textSize="13sp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
