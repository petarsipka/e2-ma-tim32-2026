<?xml version="1.0" encoding="utf-8"?>
<!-- Asocijacije — Sunny pop in-game. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_gradient">

    <include layout="@layout/layout_stats_bar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="4dp"
            android:paddingBottom="18dp">

            <!-- Strip -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/tvRound"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_chip"
                    android:fontFamily="@font/baloo2"
                    android:paddingStart="11dp"
                    android:paddingEnd="11dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:text="Runda 1 / 2"
                    android:textColor="@color/text"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvScore"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/baloo2"
                    android:gravity="center"
                    android:text="Bodovi: 0"
                    android:textColor="@color/accent"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <com.example.slagalica.ui.widget.GameTimerView
                    android:id="@+id/tvTimer"
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:text="2:00"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- 4-column grid -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout style="@style/AsocColumn" android:layout_marginEnd="3dp">
                    <Button android:id="@+id/btnC1F1" style="@style/AsocCell" />
                    <Button android:id="@+id/btnC1F2" style="@style/AsocCell" />
                    <Button android:id="@+id/btnC1F3" style="@style/AsocCell" />
                    <Button android:id="@+id/btnC1F4" style="@style/AsocCell" />
                    <Button android:id="@+id/btnSolC1" style="@style/AsocSol" />
                </LinearLayout>

                <LinearLayout style="@style/AsocColumn" android:layout_marginStart="3dp" android:layout_marginEnd="3dp">
                    <Button android:id="@+id/btnC2F1" style="@style/AsocCell" />
                    <Button android:id="@+id/btnC2F2" style="@style/AsocCell" />
                    <Button android:id="@+id/btnC2F3" style="@style/AsocCell" />
                    <Button android:id="@+id/btnC2F4" style="@style/AsocCell" />
                    <Button android:id="@+id/btnSolC2" style="@style/AsocSol" />
                </LinearLayout>

                <LinearLayout style="@style/AsocColumn" android:layout_marginStart="3dp" android:layout_marginEnd="3dp">
                    <Button android:id="@+id/btnC3F1" style="@style/AsocCell" />
                    <Button android:id="@+id/btnC3F2" style="@style/AsocCell" />
                    <Button android:id="@+id/btnC3F3" style="@style/AsocCell" />
                    <Button android:id="@+id/btnC3F4" style="@style/AsocCell" />
                    <Button android:id="@+id/btnSolC3" style="@style/AsocSol" />
                </LinearLayout>

                <LinearLayout style="@style/AsocColumn" android:layout_marginStart="3dp">
                    <Button android:id="@+id/btnC4F1" style="@style/AsocCell" />
                    <Button android:id="@+id/btnC4F2" style="@style/AsocCell" />
                    <Button android:id="@+id/btnC4F3" style="@style/AsocCell" />
                    <Button android:id="@+id/btnC4F4" style="@style/AsocCell" />
                    <Button android:id="@+id/btnSolC4" style="@style/AsocSol" />
                </LinearLayout>
            </LinearLayout>

            <!-- Column guess rows -->
            <LinearLayout android:id="@+id/rowGuessC1" style="@style/AsocGuessRow" android:layout_marginTop="10dp">
                <EditText android:id="@+id/etGuessC1" style="@style/AsocGuessInput" android:hint="Kolona 1…" />
                <Button android:id="@+id/btnGuessC1" style="@style/AsocGuessBtn" android:text="Pogodi" />
            </LinearLayout>

            <LinearLayout android:id="@+id/rowGuessC2" style="@style/AsocGuessRow">
                <EditText android:id="@+id/etGuessC2" style="@style/AsocGuessInput" android:hint="Kolona 2…" />
                <Button android:id="@+id/btnGuessC2" style="@style/AsocGuessBtn" android:text="Pogodi" />
            </LinearLayout>

            <LinearLayout android:id="@+id/rowGuessC3" style="@style/AsocGuessRow">
                <EditText android:id="@+id/etGuessC3" style="@style/AsocGuessInput" android:hint="Kolona 3…" />
                <Button android:id="@+id/btnGuessC3" style="@style/AsocGuessBtn" android:text="Pogodi" />
            </LinearLayout>

            <LinearLayout android:id="@+id/rowGuessC4" style="@style/AsocGuessRow">
                <EditText android:id="@+id/etGuessC4" style="@style/AsocGuessInput" android:hint="Kolona 4…" />
                <Button android:id="@+id/btnGuessC4" style="@style/AsocGuessBtn" android:text="Pogodi" />
            </LinearLayout>

            <!-- Final solution -->
            <Button
                android:id="@+id/btnFinalSolution"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="8dp"
                android:backgroundTint="@color/accent"
                android:fontFamily="@font/baloo2"
                android:text="KONAČNO REŠENJE"
                android:textColor="@color/on_accent"
                android:textSize="14sp"
                android:textStyle="bold"
                app:cornerRadius="@dimen/radius"
                xmlns:app="http://schemas.android.com/apk/res-auto" />

            <LinearLayout style="@style/AsocGuessRow">
                <EditText android:id="@+id/etGuessFinal" style="@style/AsocGuessInput" android:hint="Konačno rešenje…" />
                <Button android:id="@+id/btnGuessFinal" style="@style/AsocGuessBtn" android:text="Pogodi" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
