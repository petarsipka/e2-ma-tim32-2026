<?xml version="1.0" encoding="utf-8"?>
<!-- Asocijacije — Sunny pop in-game (design: .gscr). Open fields, then tap a
     column solution or the final banner to type your guess. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_gradient">

    <include layout="@layout/layout_stats_bar" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="2dp"
        android:paddingBottom="18dp">

        <!-- Title row: game name + rule subtitle, timer ring (.gtitle-row) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/baloo2"
                    android:text="Asocijacije"
                    android:textColor="@color/text"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="1dp"
                    android:fontFamily="@font/nunito"
                    android:text="Otvaraj polja i pogađaj rešenja"
                    android:textColor="@color/muted"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <com.example.slagalica.ui.widget.GameTimerView
                android:id="@+id/tvTimer"
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:text="2:00"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- 4-column grid (.asoc-grid) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <LinearLayout style="@style/AsocColumn" android:layout_marginEnd="3dp">
                <TextView android:id="@+id/btnC1F1" style="@style/AsocCell" />
                <TextView android:id="@+id/btnC1F2" style="@style/AsocCell" />
                <TextView android:id="@+id/btnC1F3" style="@style/AsocCell" />
                <TextView android:id="@+id/btnC1F4" style="@style/AsocCell" />
                <TextView android:id="@+id/btnSolC1" style="@style/AsocSol" />
            </LinearLayout>

            <LinearLayout style="@style/AsocColumn" android:layout_marginStart="3dp" android:layout_marginEnd="3dp">
                <TextView android:id="@+id/btnC2F1" style="@style/AsocCell" />
                <TextView android:id="@+id/btnC2F2" style="@style/AsocCell" />
                <TextView android:id="@+id/btnC2F3" style="@style/AsocCell" />
                <TextView android:id="@+id/btnC2F4" style="@style/AsocCell" />
                <TextView android:id="@+id/btnSolC2" style="@style/AsocSol" />
            </LinearLayout>

            <LinearLayout style="@style/AsocColumn" android:layout_marginStart="3dp" android:layout_marginEnd="3dp">
                <TextView android:id="@+id/btnC3F1" style="@style/AsocCell" />
                <TextView android:id="@+id/btnC3F2" style="@style/AsocCell" />
                <TextView android:id="@+id/btnC3F3" style="@style/AsocCell" />
                <TextView android:id="@+id/btnC3F4" style="@style/AsocCell" />
                <TextView android:id="@+id/btnSolC3" style="@style/AsocSol" />
            </LinearLayout>

            <LinearLayout style="@style/AsocColumn" android:layout_marginStart="3dp">
                <TextView android:id="@+id/btnC4F1" style="@style/AsocCell" />
                <TextView android:id="@+id/btnC4F2" style="@style/AsocCell" />
                <TextView android:id="@+id/btnC4F3" style="@style/AsocCell" />
                <TextView android:id="@+id/btnC4F4" style="@style/AsocCell" />
                <TextView android:id="@+id/btnSolC4" style="@style/AsocSol" />
            </LinearLayout>
        </LinearLayout>

        <!-- Final solution banner (.asoc-final) — tap to type -->
        <LinearLayout
            android:id="@+id/btnFinalSolution"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_accent_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/nunito"
                android:letterSpacing="0.2"
                android:text="KONAČNO REŠENJE"
                android:textColor="@color/on_accent_muted"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvFinalValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/baloo2"
                android:letterSpacing="0.08"
                android:textColor="@color/on_accent"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Bottom strip: columns solved + points (.gstrip) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvSolvedColumns"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip"
                android:fontFamily="@font/baloo2"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="7dp"
                android:paddingBottom="7dp"
                android:text="⚡ 0 kolona rešeno"
                android:textColor="@color/text"
                android:textSize="12sp"
                android:textStyle="bold" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tvRoundPoints"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip"
                android:fontFamily="@font/baloo2"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="7dp"
                android:paddingBottom="7dp"
                android:text="+0 bodova"
                android:textColor="@color/star"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>
</LinearLayout>
