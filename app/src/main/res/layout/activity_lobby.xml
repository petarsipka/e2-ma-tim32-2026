<?xml version="1.0" encoding="utf-8"?>
<!-- Match lobby: host shows a QR (+ code), guest scans it or types the code. -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:overScrollMode="never"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/screen_pad"
        android:paddingEnd="@dimen/screen_pad"
        android:paddingTop="40dp"
        android:paddingBottom="24dp">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_chip"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="@font/baloo2"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="9dp"
            android:paddingBottom="9dp"
            android:text="‹ Nazad"
            android:textColor="@color/accent"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:fontFamily="@font/baloo2"
            android:text="Duel 1-na-1"
            android:textColor="@color/text"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/nunito"
            android:text="Napravi partiju i pokaži QR, ili skeniraj protivnikov."
            android:textColor="@color/muted"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- Initial actions -->
        <LinearLayout
            android:id="@+id/llActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical">

            <Button
                android:id="@+id/btnCreate"
                style="@style/Widget.Slagalica.Button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Napravi partiju"
                android:textSize="17sp" />

            <Button
                android:id="@+id/btnScan"
                style="@style/Widget.Slagalica.Button.Ghost"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="10dp"
                android:text="Skeniraj QR kod"
                android:textSize="17sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/nunito"
                android:gravity="center"
                android:letterSpacing="0.1"
                android:text="ILI UNESI KOD"
                android:textColor="@color/muted"
                android:textSize="11sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etCode"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_field"
                android:fontFamily="@font/baloo2"
                android:gravity="center"
                android:hint="ABC123"
                android:inputType="textCapCharacters"
                android:maxLength="6"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="@color/text"
                android:textColorHint="@color/faint"
                android:letterSpacing="0.2"
                android:textSize="20sp" />

            <Button
                android:id="@+id/btnJoinCode"
                style="@style/Widget.Slagalica.Button.Ghost"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:text="Pridruži se kodom"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- Host waiting state -->
        <LinearLayout
            android:id="@+id/llHost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_card_lg"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="20dp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/ivQr"
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:background="@color/white"
                android:padding="8dp"
                android:contentDescription="QR kod partije" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:fontFamily="@font/nunito"
                android:letterSpacing="0.1"
                android:text="KOD PARTIJE"
                android:textColor="@color/muted"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/baloo2"
                android:letterSpacing="0.25"
                android:text="——————"
                android:textColor="@color/accent"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvWaiting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="@font/nunito"
                android:text="Čekam protivnika…"
                android:textColor="@color/muted"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
