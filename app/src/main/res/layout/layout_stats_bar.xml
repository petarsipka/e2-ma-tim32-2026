<?xml version="1.0" encoding="utf-8"?>
<!-- Shared in-game header (Sunny pop .gstrip + .score):
     currency chips + quit, with the reusable match scoreboard below. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_gradient"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="12dp"
    android:paddingBottom="6dp">

    <!-- Currency chips + quit (.gstrip) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginTop="40dp">

        <TextView
            android:id="@+id/tvNavTokens"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_chip"
            android:fontFamily="@font/baloo2"
            android:paddingStart="11dp"
            android:paddingEnd="11dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:text="🪙 150"
            android:textColor="@color/token"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvNavStars"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_chip"
            android:fontFamily="@font/baloo2"
            android:paddingStart="11dp"
            android:paddingEnd="11dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:text="⭐ 45"
            android:textColor="@color/star"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvNavLeague"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_chip"
            android:fontFamily="@font/baloo2"
            android:paddingStart="11dp"
            android:paddingEnd="11dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:text="🏆 Zlatna"
            android:textColor="@color/league_text"
            android:textSize="12sp"
            android:textStyle="bold" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/btnNavQuit"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="@drawable/bg_quit"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="@font/nunito"
            android:gravity="center"
            android:text="✕"
            android:textColor="@color/muted"
            android:textSize="17sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Reusable match scoreboard (.score) -->
    <include
        layout="@layout/view_score"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp" />

</LinearLayout>
