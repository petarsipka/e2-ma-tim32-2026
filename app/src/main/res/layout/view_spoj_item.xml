<?xml version="1.0" encoding="utf-8"?>
<!-- Inner content of SpojItemView (Sunny pop .spoj-item): centred label + corner badge. -->
<merge xmlns:android="http://schemas.android.com/apk/res/android">

    <TextView
        android:id="@+id/spojText"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fontFamily="@font/nunito"
        android:gravity="center"
        android:lineSpacingMultiplier="1.12"
        android:paddingStart="11dp"
        android:paddingEnd="11dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:textColor="@color/text"
        android:textSize="13sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/spojBadge"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="7dp"
        android:background="@drawable/bg_spoj_badge"
        android:fontFamily="@font/baloo2"
        android:gravity="center"
        android:includeFontPadding="false"
        android:textColor="@color/white"
        android:textSize="10sp"
        android:textStyle="bold"
        android:visibility="gone" />

</merge>
