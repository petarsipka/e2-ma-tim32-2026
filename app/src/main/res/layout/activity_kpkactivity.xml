<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F0F5">
    <include layout="@layout/layout_stats_bar" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="6dp">

            <!-- Header -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/kpkGameTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="Korak po Korak"
                    android:textColor="#272794"
                    android:textSize="28sp"
                    android:textStyle="bold|italic" />

                <TextView
                    android:id="@+id/kbkTimer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end|center_vertical"
                    android:text="70s"
                    android:textColor="#D32F2F"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <!-- Round -->
            <TextView
                android:id="@+id/kbkRoundNum"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="8dp"
                android:text="Runda -/-"
                android:textColor="#272794"
                android:textSize="18sp"
                android:textStyle="bold|italic" />

            <!-- 7 Hint cards -->
            <TextView
                android:id="@+id/kbkHint1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="8dp"
                android:background="#FFFFFF"
                android:gravity="center"
                android:padding="16dp"
                android:text="Hint 1"
                android:textColor="#272794"
                android:textSize="22sp"
                android:elevation="2dp"/>

            <TextView
                android:id="@+id/kbkHint2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="8dp"
                android:background="#FFFFFF"
                android:gravity="center"
                android:padding="16dp"
                android:text="Hint 2"
                android:textColor="#272794"
                android:textSize="22sp"
                android:elevation="2dp"/>

            <TextView
                android:id="@+id/kbkHint3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="8dp"
                android:background="#FFFFFF"
                android:gravity="center"
                android:padding="16dp"
                android:text="Hint 3"
                android:textColor="#272794"
                android:textSize="22sp"
                android:elevation="2dp"/>

            <TextView
                android:id="@+id/kbkHint4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="8dp"
                android:background="#FFFFFF"
                android:gravity="center"
                android:padding="16dp"
                android:text="Hint 4"
                android:textColor="#272794"
                android:textSize="22sp"
                android:elevation="2dp"/>

            <TextView
                android:id="@+id/kbkHint5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="8dp"
                android:background="#FFFFFF"
                android:gravity="center"
                android:padding="16dp"
                android:text="Hint 5"
                android:textColor="#272794"
                android:textSize="22sp"
                android:elevation="2dp"/>

            <TextView
                android:id="@+id/kbkHint6"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="8dp"
                android:background="#FFFFFF"
                android:gravity="center"
                android:padding="16dp"
                android:text="Hint 6"
                android:textColor="#272794"
                android:textSize="22sp"
                android:elevation="2dp"/>

            <TextView
                android:id="@+id/kbkHint7"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="8dp"
                android:background="#FFFFFF"
                android:gravity="center"
                android:padding="16dp"
                android:text="Hint 7"
                android:textColor="#272794"
                android:textSize="22sp"
                android:elevation="2dp"/>

            <!-- Spacer -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />


            <!-- Bottom row: Points | Input | Button -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/kbkPointsCounter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp"
                    android:text="0"
                    android:textColor="#272794"
                    android:textSize="32sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/kbkInputAnswer"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Rešenje:"
                    android:inputType="text"
                    android:minHeight="48dp"
                    android:padding="12dp"
                    android:textSize="16sp" />

                <Button
                    android:id="@+id/kbkSendButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:backgroundTint="#272794"
                    android:text="Pošalji"
                    android:textColor="#FFFFFF" />
            </LinearLayout>

            <!-- Opponent status -->
            <TextView
                android:id="@+id/kbkOpponentCheck"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:text="Vaš je potez."
                android:textColor="#666666"
                android:textSize="14sp" />

        </LinearLayout>
</LinearLayout>
