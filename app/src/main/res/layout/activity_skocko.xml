            android:layout_margin="2dp"
            android:layout_weight="1"
            android:background="@drawable/skocko_feedback_circle" />
    </LinearLayout>

    <!-- ANSWER REVEAL ROW (always shown at end of round) -->
    <LinearLayout
        android:id="@+id/skAnswerRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="6dp"
        android:orientation="horizontal"
        android:visibility="visible"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/skStealRow"
        app:layout_constraintWidth_percent="0.50">

        <ImageView
            android:id="@+id/skAnsSlot1"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_margin="3dp"
            android:layout_weight="1"
            android:background="@drawable/skocko_symbol_slot"
            android:scaleType="fitCenter" />

        <ImageView
            android:id="@+id/skAnsSlot2"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_margin="3dp"
            android:layout_weight="1"
            android:background="@drawable/skocko_symbol_slot"
            android:scaleType="fitCenter" />

        <ImageView
            android:id="@+id/skAnsSlot3"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_margin="3dp"
            android:layout_weight="1"
            android:background="@drawable/skocko_symbol_slot"
            android:scaleType="fitCenter" />

        <ImageView
            android:id="@+id/skAnsSlot4"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_margin="3dp"
            android:layout_weight="1"
            android:background="@drawable/skocko_symbol_slot"
            android:scaleType="fitCenter" />
    </LinearLayout>

    <TextView
        android:id="@+id/skAnswerLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/nunito"
        android:text="TAČAN ODGOVOR"
        android:textColor="@color/muted"
        android:textSize="11sp"
        android:textStyle="bold"
        android:visibility="invisible"
        app:layout_constraintTop_toBottomOf="@id/skStealRow"
        app:layout_constraintBottom_toTopOf="@id/skAnswerRow"
        app:layout_constraintStart_toStartOf="@id/skAnswerRow" />

    <!-- Symbol picker buttons (right side) -->
    <ImageButton
        android:id="@+id/skOptionSkocko"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="14dp"
        android:background="@drawable/skocko_symbol_slot"
        android:padding="4dp"
        android:scaleType="fitCenter"
        android:src="@drawable/skocko"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/skSymbolRow1" />

    <ImageButton
        android:id="@+id/skOptionTref"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="14dp"
        android:background="@drawable/skocko_symbol_slot"
        android:padding="4dp"
        android:scaleType="fitCenter"
        android:src="@drawable/tref"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/skOptionSkocko" />

    <ImageButton
        android:id="@+id/skOptionPik"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="14dp"
        android:background="@drawable/skocko_symbol_slot"
        android:padding="4dp"
        android:scaleType="fitCenter"
        android:src="@drawable/pik"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/skOptionTref" />

    <ImageButton
        android:id="@+id/skOptionSrce"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="14dp"
        android:background="@drawable/skocko_symbol_slot"
        android:padding="4dp"
        android:scaleType="fitCenter"
        android:src="@drawable/srce"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/skOptionPik" />

    <ImageButton
        android:id="@+id/skOptionKaro"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="14dp"
        android:background="@drawable/skocko_symbol_slot"
        android:padding="4dp"
        android:scaleType="fitCenter"
        android:src="@drawable/karo"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/skOptionSrce" />

    <ImageButton
        android:id="@+id/skOptionZvezda"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="14dp"
        android:background="@drawable/skocko_symbol_slot"
        android:padding="4dp"
        android:scaleType="fitCenter"
        android:src="@drawable/zvezda"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/skOptionKaro" />

    <!-- Backspace + Submit row -->
    <LinearLayout
        android:id="@+id/skControls"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="12dp"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/skAnswerRow">

        <TextView
            android:id="@+id/skBackspace"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_circle_accent"
            android:fontFamily="@font/baloo2"
            android:gravity="center"
            android:text="X"
            android:textColor="@color/on_accent"
            android:textSize="18sp"
            android:textStyle="bold" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/skSubmit"
            style="@style/Widget.Slagalica.Button"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:minWidth="100dp"
            android:text="Pošalji"
            android:textSize="13sp"
            android:gravity="center"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>