<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_card"
    android:gravity="center_vertical"
    android:padding="14dp"
    android:layout_marginBottom="8dp">

    <TextView
        android:id="@+id/notifType"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:gravity="center"
        android:textSize="20sp"
        android:layout_marginEnd="12dp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/notifTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/baloo2"
                android:text="Naslov"
                android:textColor="@color/text"
                android:textSize="15sp"
                android:textStyle="bold" />

            <View
                android:id="@+id/notifUnreadDot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_unread_dot"
                android:layout_marginStart="6dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/notifMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="@font/nunito"
            android:text="Poruka obaveštenja"
            android:textColor="@color/muted"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/notifTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/nunito"
            android:text="12.06. 14:30"
            android:textColor="@color/faint"
            android:textSize="11sp" />
    </LinearLayout>
</LinearLayout>