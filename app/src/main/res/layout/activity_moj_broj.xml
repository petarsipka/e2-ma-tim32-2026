<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F0F5">
    <include layout="@layout/layout_stats_bar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:gravity="center_horizontal">

            <!-- Header: Title + Timer -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/mbGameTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Moj Broj"
                    android:textColor="#272794"
                    android:textSize="28sp"
                    android:textStyle="bold|italic" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/mbTimer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="60s"
                    android:textColor="#D32F2F"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Target Number Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/mb_numbers_big"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TRAŽENI BROJ"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/mbWantedNum"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="---"
                    android:textColor="#272794"
                    android:textSize="44sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Player Answers -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/mbPlayer1Answer"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="P1: ???"
                    android:textColor="#272794"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/mbPlayer2Answer"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="P2: ???"
                    android:textColor="#272794"
                    android:textSize="16sp"
                    android:gravity="end" />
            </LinearLayout>

            <!-- 4 Small Numbers -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DOSTUPNI BROJEVI"
                android:textSize="12sp"
                android:textColor="#666666"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/mbUsedNum1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/mb_numbers"
                    android:gravity="center"
                    android:padding="14dp"
                    android:text="1"
                    android:textColor="#272794"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/mbUsedNum2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/mb_numbers"
                    android:gravity="center"
                    android:padding="14dp"
                    android:text="2"
                    android:textColor="#272794"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/mbUsedNum3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/mb_numbers"
                    android:gravity="center"
                    android:padding="14dp"
                    android:text="3"
                    android:textColor="#272794"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/mbUsedNum4"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/mb_numbers"
                    android:gravity="center"
                    android:padding="14dp"
                    android:text="4"
                    android:textColor="#272794"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- 2 Big Numbers -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <TextView
                    android:id="@+id/mbUsedNum5"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/mb_numbers_big"
                    android:gravity="center"
                    android:padding="16dp"
                    android:text="10"
                    android:textColor="#D84315"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/mbUsedNum6"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/mb_numbers_big"
                    android:gravity="center"
                    android:padding="16dp"
                    android:text="25"
                    android:textColor="#D84315"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Operators -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OPERATORI"
                android:textSize="12sp"
                android:textColor="#666666"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <TextView
                    android:id="@+id/mbLParen"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/mb_operators"
                    android:gravity="center"
                    android:padding="12dp"
                    android:text="("
                    android:textColor="#272794"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/mbRParen"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/mb_operators"
                    android:gravity="center"
                    android:padding="12dp"
                    android:text=")"
                    android:textColor="#272794"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/mbPlus"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/mb_operators"
                    android:gravity="center"
                    android:padding="12dp"
                    android:text="+"
                    android:textColor="#272794"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/mbMinus"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/mb_operators"
                    android:gravity="center"
                    android:padding="12dp"
                    android:text="-"
                    android:textColor="#272794"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/mbMultiply"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/mb_operators"
                    android:gravity="center"
                    android:padding="12dp"
                    android:text="×"
                    android:textColor="#272794"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/mbDivide"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/mb_operators"
                    android:gravity="center"
                    android:padding="12dp"
                    android:text="÷"
                    android:textColor="#272794"
                    android:textSize="20sp" />
            </LinearLayout>

            <!-- Separator -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#CCCCCC"
                android:layout_marginBottom="16dp" />

            <!-- Expression Input -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VAŠ IZRAZ"
                android:textSize="12sp"
                android:textColor="#666666"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/mbInsertAnswer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Unesite rešenje..."
                android:minHeight="48dp"
                android:padding="12dp"
                android:textSize="18sp"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/mbSendButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="#272794"
                android:text="POŠALJI"
                android:textColor="#FFFFFF"
                android:textSize="16sp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>