<?xml version="1.0" encoding="utf-8"?>
<!-- Registracija — Sunny pop onboarding. -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:fillViewport="true"
    tools:context=".ui.RegisterActivity">

    <LinearLayout
        android:id="@+id/linearLayout1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="28dp"
        android:paddingBottom="24dp">

        <include layout="@layout/view_brand" />

        <TextView
            android:id="@+id/rgRegisterTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="20dp"
            android:fontFamily="@font/baloo2"
            android:text="Napravi nalog"
            android:textColor="@color/text"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="24dp"
            android:fontFamily="@font/nunito"
            android:text="Pridruži se takmičenju"
            android:textColor="@color/muted"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView style="@style/FieldLabel" android:text="EMAIL" />

        <EditText
            android:id="@+id/rgInsertEmail"
            style="@style/FieldInput"
            android:layout_marginBottom="14dp"
            android:hint="npr. milos@primer.rs"
            android:inputType="textEmailAddress" />

        <TextView style="@style/FieldLabel" android:text="KORISNIČKO IME" />

        <EditText
            android:id="@+id/rgInsertUsername"
            style="@style/FieldInput"
            android:layout_marginBottom="14dp"
            android:hint="npr. milos99"
            android:inputType="text" />

        <TextView
            android:id="@+id/rgRegionHint"
            style="@style/FieldLabel"
            android:text="REGION" />

        <Spinner
            android:id="@+id/rgSpinnerRegion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:background="@drawable/bg_field"
            android:entries="@array/regions"
            android:minHeight="52dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:popupBackground="@drawable/bg_card"
            android:spinnerMode="dropdown" />

        <TextView style="@style/FieldLabel" android:text="LOZINKA" />

        <EditText
            android:id="@+id/rgInsertPassword"
            style="@style/FieldInput"
            android:layout_marginBottom="14dp"
            android:hint="••••••••"
            android:inputType="textPassword" />

        <TextView style="@style/FieldLabel" android:text="PONOVI LOZINKU" />

        <EditText
            android:id="@+id/rgInsertRepeatPassword"
            style="@style/FieldInput"
            android:hint="••••••••"
            android:inputType="textPassword" />

        <Button
            android:id="@+id/rgRegisterButton"
            style="@style/Widget.Slagalica.Button"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="26dp"
            android:text="Registruj se"
            android:textSize="16sp"
            app:cornerRadius="@dimen/radius" />

        <TextView
            android:id="@+id/rgLoginLink"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="22dp"
            android:fontFamily="@font/nunito"
            android:text="Već imaš nalog?  Prijavi se"
            android:textColor="@color/accent"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>
</ScrollView>
