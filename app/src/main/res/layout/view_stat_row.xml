<?xml version="1.0" encoding="utf-8"?>
<!-- One per-game average row (Sunny pop .stat-row): name + fill bar + range. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingTop="7dp"
    android:paddingBottom="7dp">

    <TextView
        android:id="@+id/statName"
        android:layout_width="96dp"
        android:layout_height="wrap_content"
        android:fontFamily="@font/nunito"
        android:textColor="@color/text"
        android:textSize="12sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/statTrack"
        android:layout_width="0dp"
        android:layout_height="8dp"
        android:layout_weight="1"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:background="@drawable/bg_stat_track"
        android:orientation="horizontal"
        android:weightSum="100">

        <View
            android:id="@+id/statFill"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:background="@drawable/bg_stat_fill" />

        <View
            android:id="@+id/statSpacer"
            android:layout_width="0dp"
            android:layout_height="match_parent" />
    </LinearLayout>

    <TextView
        android:id="@+id/statValue"
        android:layout_width="52dp"
        android:layout_height="wrap_content"
        android:fontFamily="@font/baloo2"
        android:gravity="end"
        android:textColor="@color/muted"
        android:textSize="11sp"
        android:textStyle="bold" />
</LinearLayout>
