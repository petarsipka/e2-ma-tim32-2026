<?xml version="1.0" encoding="utf-8"?>
<!-- One game-result row on the result screen: icon · name · myScore : oppScore. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="9dp"
    android:background="@drawable/bg_card"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="13dp"
    android:paddingEnd="16dp"
    android:paddingTop="11dp"
    android:paddingBottom="11dp">

    <TextView
        android:id="@+id/resIcon"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:background="@drawable/bg_tile_g0"
        android:gravity="center"
        android:text="?"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/resName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:fontFamily="@font/baloo2"
        android:text="Igra"
        android:textColor="@color/text"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/resMy"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/baloo2"
        android:text="0"
        android:textColor="@color/accent"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp"
        android:layout_marginEnd="6dp"
        android:fontFamily="@font/baloo2"
        android:text=":"
        android:textColor="@color/faint"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/resOpp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/baloo2"
        android:text="0"
        android:textColor="@color/accent2"
        android:textSize="15sp"
        android:textStyle="bold" />
</LinearLayout>
