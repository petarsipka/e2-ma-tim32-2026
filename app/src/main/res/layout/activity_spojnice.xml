<?xml version="1.0" encoding="utf-8"?>
<!-- Spojnice — Sunny pop in-game (pairs colored, no lines). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_gradient">

    <include layout="@layout/layout_stats_bar" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="4dp"
        android:paddingBottom="18dp">

        <!-- Strip -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <TextView
                android:id="@+id/tvRound"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip"
                android:fontFamily="@font/baloo2"
                android:paddingStart="11dp"
                android:paddingEnd="11dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:text="Runda 1 / 2"
                android:textColor="@color/text"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvScore"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/baloo2"
                android:gravity="center"
                android:text="Bodovi: 0"
                android:textColor="@color/accent"
                android:textSize="15sp"
                android:textStyle="bold" />

            <com.example.slagalica.ui.widget.GameTimerView
                android:id="@+id/tvTimer"
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:text="0:30"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Criterion -->
        <TextView
            android:id="@+id/tvCriterion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:fontFamily="@font/baloo2"
            android:gravity="center"
            android:padding="14dp"
            android:textColor="@color/text"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="14dp" />

        <!-- Two columns -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:orientation="vertical">

                <Button android:id="@+id/btnL1" style="@style/SpojButton" />
                <Button android:id="@+id/btnL2" style="@style/SpojButton" />
                <Button android:id="@+id/btnL3" style="@style/SpojButton" />
                <Button android:id="@+id/btnL4" style="@style/SpojButton" />
                <Button android:id="@+id/btnL5" style="@style/SpojButton" android:layout_marginBottom="0dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:orientation="vertical">

                <Button android:id="@+id/btnR1" style="@style/SpojButton" />
                <Button android:id="@+id/btnR2" style="@style/SpojButton" />
                <Button android:id="@+id/btnR3" style="@style/SpojButton" />
                <Button android:id="@+id/btnR4" style="@style/SpojButton" />
                <Button android:id="@+id/btnR5" style="@style/SpojButton" android:layout_marginBottom="0dp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/nunito"
            android:gravity="center"
            android:text="Dodirni pojam levo pa njegov par desno"
            android:textColor="@color/muted"
            android:textSize="11sp"
            android:textStyle="bold" />

    </LinearLayout>
</LinearLayout>
