<?xml version="1.0" encoding="utf-8"?>
<!-- Spojnice column tile, wrong/locked state (Sunny pop .wrong):
     light red fill with a red border; the choice can no longer be tried. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/wrong_bg" />
    <stroke android:width="1.5dp" android:color="@color/wrong" />
    <corners android:radius="@dimen/radius_sm" />
</shape>
