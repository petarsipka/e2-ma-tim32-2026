<?xml version="1.0" encoding="utf-8"?>
<!-- Accent gradient pill with ripple (Sunny pop .guess-btn / .play-mini). -->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#40FFFFFF">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="315"
                android:startColor="@color/accent"
                android:endColor="@color/accent_end" />
            <corners android:radius="@dimen/radius_pill" />
        </shape>
    </item>
</ripple>
