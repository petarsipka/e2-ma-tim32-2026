<?xml version="1.0" encoding="utf-8"?>
<!-- Profile QR button (Sunny pop .qr-btn): filled field, small radius. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/field" />
    <stroke android:width="1dp" android:color="@color/field_border" />
    <corners android:radius="@dimen/radius_sm" />
</shape>
