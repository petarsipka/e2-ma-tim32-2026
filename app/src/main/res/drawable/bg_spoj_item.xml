<?xml version="1.0" encoding="utf-8"?>
<!-- Spojnice column tile, neutral state (Sunny pop .spoj-item):
     white panel, soft 1.5dp border, small radius. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/panel" />
    <stroke android:width="1.5dp" android:color="@color/field_border" />
    <corners android:radius="@dimen/radius_sm" />
</shape>
