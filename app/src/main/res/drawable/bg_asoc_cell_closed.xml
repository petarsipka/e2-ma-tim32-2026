<?xml version="1.0" encoding="utf-8"?>
<!-- Asocijacije closed field / solution cell (Sunny pop .asoc-cell.closed):
     filled field colour, soft border, small 9dp radius. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/field" />
    <stroke android:width="1.5dp" android:color="@color/field_border" />
    <corners android:radius="9dp" />
</shape>
