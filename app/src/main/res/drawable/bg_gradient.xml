<?xml version="1.0" encoding="utf-8"?>
<!-- App background: warm cream radial wash (Sunny pop bg-grad). -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:type="radial"
        android:gradientRadius="640dp"
        android:centerX="0.5"
        android:centerY="0.0"
        android:startColor="@color/bg_grad_start"
        android:centerColor="@color/bg_grad_mid"
        android:endColor="@color/bg_grad_end" />
</shape>
