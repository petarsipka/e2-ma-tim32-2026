<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Game tile card (Sunny pop .gtile) -->
    <style name="GameTileCard" parent="Widget.Material3.CardView.Outlined">
        <item name="android:layout_height">96dp</item>
        <item name="cardCornerRadius">17dp</item>
        <item name="cardElevation">0dp</item>
        <item name="cardBackgroundColor">@color/panel</item>
        <item name="strokeColor">@color/pill_border</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="rippleColor">#22FF6A3D</item>
    </style>

    <style name="GameTileInner" parent="">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">8dp</item>
    </style>

    <!-- Colored icon chip inside a game tile -->
    <style name="GameTileIcon" parent="">
        <item name="android:layout_width">42dp</item>
        <item name="android:layout_height">42dp</item>
        <item name="android:layout_marginBottom">8dp</item>
        <item name="android:gravity">center</item>
        <item name="android:fontFamily">@font/baloo2</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/on_accent</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="GameTileName" parent="">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:fontFamily">@font/nunito</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text</item>
        <item name="android:textSize">12sp</item>
        <item name="android:gravity">center</item>
    </style>

    <!-- Profile per-game stat row -->
    <style name="ProfileStatRow" parent="">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:paddingTop">11dp</item>
        <item name="android:paddingBottom">11dp</item>
    </style>

    <style name="ProfileStatTitle" parent="">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:fontFamily">@font/baloo2</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="ProfileStatValue" parent="">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">2dp</item>
        <item name="android:fontFamily">@font/nunito</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/muted</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="ProfileStatDivider" parent="">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:layout_marginStart">12dp</item>
        <item name="android:layout_marginEnd">12dp</item>
        <item name="android:background">@color/divider</item>
    </style>

    <!-- Form field label (Sunny pop .field-lab) -->
    <style name="FieldLabel" parent="">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">2dp</item>
        <item name="android:layout_marginBottom">6dp</item>
        <item name="android:fontFamily">@font/nunito</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.03</item>
        <item name="android:textColor">@color/muted</item>
        <item name="android:textSize">11sp</item>
    </style>

    <!-- Moj broj section label -->
    <style name="MbSectionLabel" parent="">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">8dp</item>
        <item name="android:fontFamily">@font/nunito</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:textColor">@color/muted</item>
        <item name="android:textSize">11sp</item>
    </style>

    <style name="MbTile" parent="">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:background">@drawable/mb_numbers</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">14dp</item>
        <item name="android:fontFamily">@font/baloo2</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text</item>
        <item name="android:textSize">20sp</item>
    </style>

    <style name="MbTileBig" parent="MbTile">
        <item name="android:background">@drawable/mb_numbers_big</item>
        <item name="android:textColor">@color/accent</item>
        <item name="android:textSize">22sp</item>
    </style>

    <style name="MbOp" parent="">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:background">@drawable/mb_operators</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">12dp</item>
        <item name="android:fontFamily">@font/baloo2</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/accent</item>
        <item name="android:textSize">19sp</item>
    </style>

    <!-- Korak po korak hint / step card -->
    <style name="StepCard" parent="">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">8dp</item>
        <item name="android:background">@drawable/bg_card</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">15dp</item>
        <item name="android:fontFamily">@font/baloo2</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text</item>
        <item name="android:textSize">16sp</item>
    </style>

    <!-- Asocijacije grid column -->
    <style name="AsocColumn" parent="">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:orientation">vertical</item>
    </style>

    <!-- Asocijacije field cell -->
    <style name="AsocCell" parent="Widget.Material3.Button">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:layout_marginBottom">3dp</item>
        <item name="backgroundTint">@color/accent</item>
        <item name="android:textColor">@color/on_accent</item>
        <item name="android:text">?</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">@font/nunito</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">11sp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:paddingStart">2dp</item>
        <item name="android:paddingEnd">2dp</item>
        <item name="cornerRadius">9dp</item>
    </style>

    <!-- Asocijacije solution cell -->
    <style name="AsocSol" parent="AsocCell">
        <item name="android:layout_height">48dp</item>
        <item name="android:layout_marginTop">3dp</item>
        <item name="android:layout_marginBottom">0dp</item>
        <item name="backgroundTint">@color/accent2</item>
        <item name="android:fontFamily">@font/baloo2</item>
    </style>

    <style name="AsocGuessRow" parent="">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:layout_marginTop">6dp</item>
    </style>

    <style name="AsocGuessInput" parent="FieldInput">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_marginEnd">6dp</item>
        <item name="android:minHeight">46dp</item>
        <item name="android:paddingTop">10dp</item>
        <item name="android:paddingBottom">10dp</item>
        <item name="android:inputType">text</item>
    </style>

    <style name="AsocGuessBtn" parent="Widget.Slagalica.Button">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:minHeight">46dp</item>
        <item name="android:textSize">13sp</item>
        <item name="cornerRadius">@dimen/radius_pill</item>
    </style>

    <!-- Spojnice column tile (Sunny pop .spoj-item). State handled by SpojItemView. -->
    <style name="SpojItem" parent="">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">54dp</item>
        <item name="android:layout_marginBottom">11dp</item>
    </style>

    <!-- Quiz answer option row (Sunny pop .ans): key + text + mark. -->
    <style name="AnswerRow" parent="">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">10dp</item>
        <item name="android:background">@drawable/bg_answer</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:minHeight">56dp</item>
        <item name="android:paddingStart">15dp</item>
        <item name="android:paddingEnd">15dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <!-- Answer letter key (Sunny pop .ans-k) -->
    <style name="AnswerKey" parent="">
        <item name="android:layout_width">28dp</item>
        <item name="android:layout_height">28dp</item>
        <item name="android:layout_marginEnd">12dp</item>
        <item name="android:background">@drawable/bg_answer_key</item>
        <item name="android:gravity">center</item>
        <item name="android:fontFamily">@font/baloo2</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/muted</item>
        <item name="android:textSize">14sp</item>
    </style>

    <!-- Answer text (Sunny pop .ans-t) -->
    <style name="AnswerText" parent="">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:fontFamily">@font/nunito</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text</item>
        <item name="android:textSize">15sp</item>
    </style>

    <!-- Answer correct/wrong mark (Sunny pop .ans-mark) -->
    <style name="AnswerMark" parent="">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">10dp</item>
        <item name="android:fontFamily">@font/baloo2</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">16sp</item>
    </style>

    <!-- Filled rounded input (Sunny pop .field-box) -->
    <style name="FieldInput" parent="">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/bg_field</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:paddingStart">15dp</item>
        <item name="android:paddingEnd">15dp</item>
        <item name="android:paddingTop">13dp</item>
        <item name="android:paddingBottom">13dp</item>
        <item name="android:fontFamily">@font/nunito</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text</item>
        <item name="android:textColorHint">@color/muted</item>
        <item name="android:textSize">14sp</item>
    </style>

</resources>
